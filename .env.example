# ─────────────────────────────────────────────────────────────
# OpenPath environment variables.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# --- Client-side (safe to expose; bundled into the browser app) ---
# These are PUBLIC by design. The anon key is protected by Supabase
# Row-Level Security, not by secrecy.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# --- Server-side only (Netlify Functions). NEVER prefixed with VITE_, ---
# --- so Vite will refuse to expose them to the browser bundle.        ---

# DEFAULT model provider for ALL users (free, OpenAI-compatible NVIDIA endpoint).
# This is what powers generation out of the box — set this one.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL fallback provider. Only used if NVIDIA_API_KEY is unset. Users who
# bring their own Anthropic key (BYOK) always use Anthropic for their requests.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Server-side Supabase access for the cache + rate-limit tables (NOT VITE_).
# Same project URL as VITE_SUPABASE_URL, but the secret service-role key.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Bump this string whenever a prompt changes to invalidate the AI cache.
PROMPT_VERSION=v1
